# Kopieer dit bestand naar .env en vul je eigen waarden in

# Database verbinding
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=jouw_wachtwoord
DB_NAME=taskmanager

# JWT geheime sleutel (gebruik iets longs en randoms)
JWT_SECRET=verander_dit_naar_iets_veiligs

# Poort waarop de server draait
PORT=3001
